{
  "entities": {
    "Signal": {
      "title": "Trade Signal",
      "description": "A signal generated by the AI to be picked up by MetaTrader",
      "type": "object",
      "properties": {
        "side": { "type": "string", "enum": ["BUY", "SELL"] },
        "symbol": { "type": "string" },
        "volume": { "type": "number" },
        "sl": { "type": "string" },
        "tp": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "processed"] }
      },
      "required": ["side", "symbol", "timestamp", "status"]
    }
  },
  "firestore": {
    "/signals/{signalId}": {
      "schema": "Signal",
      "description": "Collection of signals for the MetaTrader EA to poll"
    },
    "/accounts/{accountId}": {
      "schema": "AccountInfo",
      "description": "Live status of the MT5 account (Balance, Equity, etc)"
    },
    "/positions/{positionId}": {
      "schema": "Position",
      "description": "List of currently open trades in MT5"
    },
    "/history/{historyId}": {
      "schema": "History",
      "description": "List of completed trades"
    }
  }
},
"entities": {
    "AccountInfo": {
      "title": "Account Status",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "profit": { "type": "number" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    },
    "Position": {
      "title": "Open Position",
      "type": "object",
      "properties": {
        "ticket": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string" },
        "lots": { "type": "number" },
        "openPrice": { "type": "number" },
        "sl": { "type": "number" },
        "tp": { "type": "number" },
        "profit": { "type": "number" }
      }
    },
    "History": {
        "title": "Trade History",
        "type": "object",
        "properties": {
          "ticket": { "type": "string" },
          "symbol": { "type": "string" },
          "profit": { "type": "number" },
          "closeTime": { "type": "string" }
        }
    },
