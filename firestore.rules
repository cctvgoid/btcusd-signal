rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /signals/{id} { allow read, write: if true; }
    match /accounts/{id} { allow read, write: if true; }
    match /positions/{id} { allow read, write: if true; }
    match /history/{id} { allow read, write: if true; }
    
    // Recursive matches for subcollections just in case
    match /signals/{id}/{allPaths=**} { allow read, write: if true; }
    match /accounts/{id}/{allPaths=**} { allow read, write: if true; }
    match /positions/{id}/{allPaths=**} { allow read, write: if true; }
    match /history/{id}/{allPaths=**} { allow read, write: if true; }
    
    // Default tetap deny untuk yang lain
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
